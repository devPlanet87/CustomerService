@model IEnumerable<ServiceVaultWeb.Models.CustomerService>
@{
    ViewData["Title"] = "Customer Services";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Customer Services</h2>
    <a class="btn btn-primary" href="/CustomerServices/Create">Create New</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>Customer</th>
            <th>Mobile</th>
            <th>Location</th>
            <th>Product</th>
            <th>Remarks</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CustomerServiceId</td>
            <td>@(item.Customer?.CustomerName ?? item.CustomerId.ToString())</td>
            <td>@item.MobileNumber</td>
            <td>@item.Location</td>
            <td>@(item.Product?.ProductName ?? item.ProductId.ToString())</td>
            <td>@item.Remarks</td>
            <td>
                <a class="btn btn-sm btn-secondary" href="/CustomerServices/Edit/@item.CustomerServiceId">Edit</a>
            </td>
        </tr>
    }
    </tbody>
</table>
