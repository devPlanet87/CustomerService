@model IEnumerable<ServiceVaultWeb.Models.CustomerService>
@{
    ViewData["Title"] = "Customer Services";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Customer Services</h2>
    <a class="btn btn-primary btn-sm" href="/CustomerServices/Create">Create New</a>
</div>

<table class="table table-sm table-striped table-bordered table-hover small">
    <thead class="table-primary">
        <tr>
            <th>#</th>
            <th>Customer</th>
            <th>Mobile</th>
            <th>Location</th>
            <th>Product</th>
            <th>Remarks</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CustomerServiceId</td>
            <td>@(item.Customer?.CustomerName ?? item.CustomerId.ToString())</td>
            <td>@item.MobileNumber</td>
            <td>@item.Location</td>
            <td>@(item.Product?.ProductName ?? item.ProductId.ToString())</td>
            <td>@item.Remarks</td>
            <td>
                <a class="link-opacity-50-hover" href="/CustomerServices/Edit/@item.CustomerServiceId">Edit</a>
            </td>
        </tr>
    }
    </tbody>
</table>
